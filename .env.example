# --- Buffer Scheduler env ---
# NIEMALS committen. Auf Railway als Secrets eintragen, lokal als .env (in .gitignore).

# Buffer Personal API Token (Bearer). Erzeugen unter https://developers.buffer.com -> "API-Schlüssel anfordern".
BUFFER_TOKEN=

# Buffer GraphQL Endpoint. Wird beim ersten Lauf via `npm run introspect` bestätigt/korrigiert.
BUFFER_API_URL=https://graph.buffer.com/

# Deine LinkedIn-Channel-ID in Buffer. Ermitteln via `npm run channels`.
BUFFER_CHANNEL_ID=

# Zeitzone + Postzeit (24h)
TZ=Europe/Vienna
POST_HOUR=8
